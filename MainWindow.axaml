<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="550"
        Icon="/Assets/app.ico"
        x:Class="Tahoe.MainWindow"
        Title="Tahoe"
        Width="800"
        Height="500"
        Background="#050C1A">
    
        <Grid RowDefinitions="Auto, *">
                <!--Menu Bar-->
                <Menu Grid.Row="0" Background="#030812" x:Name="navBar">
                        <MenuItem Header="_Files" Foreground="#EEFFFF" x:Name="fileMenu">
                                <MenuItem Header="_Save Files" Click="saveFiles"  />
                                <Separator/>
                                <MenuItem Header="_Load Files" Click="openFiles" />
                        </MenuItem>
                        <MenuItem Header="_Themes" Foreground="#EEFFFF" x:Name="themeMenu">
                                <MenuItem Header="_Light Mode" Click="lightMode"/>
                                <MenuItem Header="_Dark Mode" Click="darkMode"/>
                        </MenuItem>
                </Menu>
                <Grid Grid.Row="1" ColumnDefinitions="Auto, *">
                <Border Grid.Column="0" Background="#0A0E17" BorderBrush="#1A2333"
                BorderThickness="0,0,1,0" x:Name="sideBar">
                        <StackPanel Margin="0,10,0,0" Spacing="15" HorizontalAlignment="Center">
                                <Button Width="36" Height="36" 
                        Background="Transparent" BorderThickness="0"
                        CornerRadius="6" HorizontalAlignment="Center" Click="openTerminal">
                    <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons" 
                               FontSize="16" Foreground="#4CAF50" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                        </StackPanel>
                </Border>
                <Grid Grid.Column="1" Background="#0D1117">
            <AvaloniaEdit:TextEditor Name="MyEditor"
                                     Margin="10"
                                     Text="// Write your code here..."
                                     ShowLineNumbers="True"
                                     FontFamily="Cascadia Code,Consolas,Monospace"
                                     FontSize="14"
                                     Foreground="#E1E4E8"
                                     Background="#0D1117"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Visible"/>
                        </Grid>
                <Grid Grid.Column="2" Height="30"  VerticalAlignment="Bottom" HorizontalAlignment="Stretch">
                        <Rectangle Fill="#0D1B2A"  />
                        <TextBlock Text="Tahoe" Foreground="#E0E1DD" HorizontalAlignment="Left" Margin="10,0,0,0" FontSize="15"
                        VerticalAlignment="Center" x:Name="statusText"/>
                </Grid>
                </Grid>
        </Grid>
</Window>
